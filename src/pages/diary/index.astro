---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/translations';

const allEntries = await getCollection('diary');
const entries = allEntries.sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
);

const totalWords = entries.reduce((sum, e) => sum + e.data.wordCount, 0);
const totalEntries = entries.length;

// 连续天数：从最新日记向前追溯
function calcStreak(sorted: typeof entries): number {
  if (sorted.length === 0) return 0;
  const desc = [...sorted].reverse();
  let streak = 1;
  for (let i = 0; i < desc.length - 1; i++) {
    const a = new Date(desc[i].data.date);
    const b = new Date(desc[i + 1].data.date);
    a.setHours(0, 0, 0, 0);
    b.setHours(0, 0, 0, 0);
    const diff = (a.getTime() - b.getTime()) / 86400000;
    if (diff === 1) streak++;
    else break;
  }
  return streak;
}
const streak = calcStreak(entries);

// 日期格式化为 yy-mm-dd（用于链接）
function toSlug(date: Date): string {
  const yy = String(date.getFullYear()).slice(2);
  const mm = String(date.getMonth() + 1).padStart(2, '0');
  const dd = String(date.getDate()).padStart(2, '0');
  return `${yy}-${mm}-${dd}`;
}

// 构建连续天数时间轴（含空缺日）
type TimelineDay =
  | { type: 'entry'; date: Date; slug: string; summary: string; summaryEn: string }
  | { type: 'empty'; date: Date };

function buildTimeline(sorted: typeof entries): TimelineDay[] {
  if (sorted.length === 0) return [];

  const entryMap = new Map<string, (typeof entries)[0]>();
  for (const e of sorted) {
    const key = e.data.date.toISOString().slice(0, 10);
    entryMap.set(key, e);
  }

  const first = new Date(sorted[0].data.date);
  const last = new Date(sorted[sorted.length - 1].data.date);
  first.setHours(0, 0, 0, 0);
  last.setHours(0, 0, 0, 0);

  const days: TimelineDay[] = [];
  const cur = new Date(first);
  while (cur <= last) {
    const key = cur.toISOString().slice(0, 10);
    const entry = entryMap.get(key);
    if (entry) {
      days.push({
        type: 'entry',
        date: new Date(cur),
        slug: toSlug(cur),
        summary: entry.data.summary,
        summaryEn: entry.data.summaryEn,
      });
    } else {
      days.push({ type: 'empty', date: new Date(cur) });
    }
    cur.setDate(cur.getDate() + 1);
  }
  return days;
}

const timeline = buildTimeline(entries);

// 按年分组
const yearGroups: Map<number, TimelineDay[]> = new Map();
for (const day of timeline) {
  const y = day.date.getFullYear();
  if (!yearGroups.has(y)) yearGroups.set(y, []);
  yearGroups.get(y)!.push(day);
}
---

<BaseLayout title="日记 - HuiYuan">
  <section class="diary-header">
    <h1 data-lang="zh">{ui.zh['diary.title']}</h1>
    <h1 data-lang="en">{ui.en['diary.title']}</h1>
    <p class="diary-subtitle" data-lang="zh">{ui.zh['diary.subtitle']}</p>
    <p class="diary-subtitle" data-lang="en">{ui.en['diary.subtitle']}</p>
  </section>

  <section class="stats">
    <div class="stat-item">
      <span class="stat-number">{totalWords.toLocaleString()}</span>
      <span class="stat-label" data-lang="zh">{ui.zh['diary.totalWords']}</span>
      <span class="stat-label" data-lang="en">{ui.en['diary.totalWords']}</span>
    </div>
    <span class="stat-sep">·</span>
    <div class="stat-item">
      <span class="stat-number">{streak}</span>
      <span class="stat-label" data-lang="zh">{ui.zh['diary.streak']}</span>
      <span class="stat-label" data-lang="en">{ui.en['diary.streak']}</span>
    </div>
    <span class="stat-sep">·</span>
    <div class="stat-item">
      <span class="stat-number">{totalEntries}</span>
      <span class="stat-label" data-lang="zh">{ui.zh['diary.entries']}</span>
      <span class="stat-label" data-lang="en">{ui.en['diary.entries']}</span>
    </div>
  </section>

  {timeline.length === 0 ? (
    <p class="empty-hint" data-lang="zh">还没有日记，快去写第一篇吧。</p>
    <p class="empty-hint" data-lang="en">No entries yet. Write the first one.</p>
  ) : (
    <div class="timeline">
      {Array.from(yearGroups.entries()).map(([year, days]) => (
        <div class="year-group">
          <div class="year-label">{year}</div>
          {days.map((day) => {
            const mmdd = `${String(day.date.getMonth() + 1).padStart(2, '0')}-${String(day.date.getDate()).padStart(2, '0')}`;
            if (day.type === 'entry') {
              return (
                <a href={`/diary/${day.slug}`} class="timeline-item">
                  <span class="tl-dot"></span>
                  <span class="tl-date">{mmdd}</span>
                  <span class="tl-summary" data-lang="zh">{day.summary}</span>
                  <span class="tl-summary" data-lang="en">{day.summaryEn}</span>
                </a>
              );
            } else {
              return (
                <div class="timeline-item timeline-item--empty">
                  <span class="tl-dot tl-dot--empty"></span>
                  <span class="tl-date tl-date--empty">{mmdd}</span>
                  <span class="tl-summary tl-summary--empty" data-lang="zh">无</span>
                  <span class="tl-summary tl-summary--empty" data-lang="en">—</span>
                </div>
              );
            }
          })}
        </div>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  .diary-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .diary-header h1 {
    margin-bottom: var(--space-sm);
  }

  .diary-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0;
  }

  .stats {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    font-family: var(--font-mono);
  }

  .stat-item {
    display: flex;
    align-items: baseline;
    gap: 0.3em;
  }

  .stat-number {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .stat-sep {
    color: var(--color-border);
    font-size: 0.9rem;
  }

  .empty-hint {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-top: var(--space-xl);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .year-group {
    display: flex;
    flex-direction: column;
  }

  .year-label {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 12px 4.5em 1fr;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.45rem 0;
    border-bottom: none;
    text-decoration: none;
  }

  a.timeline-item:hover .tl-summary {
    color: var(--color-text);
  }

  a.timeline-item:hover .tl-dot {
    background: var(--color-text);
  }

  .tl-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    justify-self: center;
    transition: background 0.15s;
  }

  .tl-dot--empty {
    background: transparent;
    border: 1px solid var(--color-border);
  }

  .tl-date {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .tl-date--empty {
    color: var(--color-border);
  }

  .tl-summary {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    transition: color 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tl-summary--empty {
    color: var(--color-border);
    font-size: 0.78rem;
  }
</style>

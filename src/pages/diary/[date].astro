---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { ui } from '../../i18n/translations';

export async function getStaticPaths() {
  const entries = await getCollection('diary');
  return entries.map((entry) => {
    const d = entry.data.date;
    const yy = String(d.getFullYear()).slice(2);
    const mm = String(d.getMonth() + 1).padStart(2, '0');
    const dd = String(d.getDate()).padStart(2, '0');
    return {
      params: { date: `${yy}-${mm}-${dd}` },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const date = entry.data.date;
const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout title={`${formattedDate} 日记 - HuiYuan`}>
  <article>
    <header class="diary-entry-header">
      <a href="/diary" class="back-link">
        <span data-lang="zh">&larr; {ui.zh['diary.back']}</span>
        <span data-lang="en">&larr; {ui.en['diary.back']}</span>
      </a>
      <time class="entry-date">{formattedDate}</time>
      <p class="entry-summary" data-lang="zh">{entry.data.summary}</p>
      <p class="entry-summary" data-lang="en">{entry.data.summaryEn}</p>
    </header>
    <div class="post-content diary-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .diary-entry-header {
    margin-bottom: var(--space-xl);
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    border-bottom: none;
    display: inline-block;
    margin-bottom: var(--space-lg);
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .entry-date {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    margin-bottom: var(--space-sm);
  }

  .entry-summary {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0;
    font-style: italic;
  }

  .diary-content {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }
</style>
